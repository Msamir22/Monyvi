{
  "name": "@monyvi/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "./index.js",
  "scripts": {
    "start": "expo start --clear",
    "android": "expo run:android",
    "android:release": "cross-env EXPO_NO_METRO_WORKSPACE_ROOT=1 npx expo run:android --variant release",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "android-local-build": "npm run prebuild && npx expo run:android --device",
    "prebuild": "npx expo prebuild",
    "start:local-supabase": "node scripts/start-local-supabase.js",
    "start:local-supabase:google": "cross-env MONYVI_LOCAL_GOOGLE_AUTH=1 node scripts/start-local-supabase.js",
    "start:e2e-fixture": "node scripts/start-e2e-fixture.js",
    "eas-android-dev": "npx expo eas-build:android --profile development",
    "eas-android-prod": "npx expo eas-build:android --profile production",
    "doctor": "npx expo-doctor",
    "install-check": "npx expo install --check",
    "expo-install": "npx expo install",
    "lint": "eslint app components config constants context hooks providers services utils validation __tests__ --rulesdir ../../scripts/eslint-rules --ext .ts,.tsx --quiet",
    "e2e": "node scripts/run-ci-e2e.js",
    "e2e:ci": "node scripts/run-ci-e2e.js",
    "e2e:seed": "node scripts/e2e-seed.js seed",
    "e2e:reset": "node scripts/e2e-seed.js reset",
    "e2e:local": "cross-env E2E_SUPABASE_MODE=local EXPO_PUBLIC_MONYVI_TEST_MODE=e2e EXPO_PUBLIC_AI_SMS_PARSER_MODE=fixture node scripts/run-ci-e2e.js",
    "e2e:flow": "node scripts/run-maestro.js test",
    "e2e:flow:local": "cross-env E2E_SUPABASE_MODE=local EXPO_PUBLIC_MONYVI_TEST_MODE=e2e EXPO_PUBLIC_AI_SMS_PARSER_MODE=fixture node scripts/run-maestro.js test",
    "e2e:auth:local": "cross-env E2E_SUPABASE_MODE=local npm run e2e:seed && cross-env E2E_SUPABASE_MODE=local EXPO_PUBLIC_MONYVI_TEST_MODE=e2e EXPO_PUBLIC_AI_SMS_PARSER_MODE=fixture E2E_CLEAR_APP_STATE=1 node scripts/run-maestro.js test e2e/maestro/helpers/ci-auth-bootstrap.yaml",
    "e2e:sms-sync": "node scripts/run-sms-sync-journeys.js",
    "e2e:sms-sync:local": "cross-env E2E_SUPABASE_MODE=local EXPO_PUBLIC_MONYVI_TEST_MODE=e2e EXPO_PUBLIC_AI_SMS_PARSER_MODE=fixture node scripts/run-sms-sync-journeys.js",
    "e2e:live-sms": "node scripts/run-live-sms-journeys.js",
    "e2e:live-sms:local": "cross-env E2E_SUPABASE_MODE=local EXPO_PUBLIC_MONYVI_TEST_MODE=e2e EXPO_PUBLIC_AI_SMS_PARSER_MODE=fixture node scripts/run-live-sms-journeys.js",
    "e2e:live-sms:release": "cross-env E2E_RELEASE_BUILD=1 node scripts/run-live-sms-journeys.js",
    "e2e:device": "node scripts/run-maestro.js test",
    "e2e:studio": "node scripts/run-maestro.js studio",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "i18n:check": "tsx scripts/check-i18n-coverage.ts",
    "i18n:update-baseline": "tsx scripts/check-i18n-coverage.ts --update-baseline"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@nozbe/watermelondb"
        ],
        "listUnknownPackages": false
      }
    }
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo-google-fonts/noto-sans-arabic": "^0.4.3",
    "@expo-google-fonts/readex-pro": "^0.4.1",
    "@expo/vector-icons": "^15.0.2",
    "@nozbe/watermelondb": "^0.28.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-navigation/native": "^7.0.14",
    "@sentry/react-native": "~7.11.0",
    "@supabase/supabase-js": "2.106.0",
    "@tanstack/react-query": "^5.90.17",
    "expo": "~55.0.24",
    "expo-asset": "~55.0.17",
    "expo-audio": "~55.0.14",
    "expo-auth-session": "~55.0.16",
    "expo-blur": "~55.0.14",
    "expo-constants": "~55.0.16",
    "expo-crypto": "~55.0.15",
    "expo-dev-client": "~55.0.34",
    "expo-file-system": "~55.0.20",
    "expo-font": "~55.0.7",
    "expo-haptics": "~55.0.14",
    "expo-linear-gradient": "~55.0.14",
    "expo-linking": "~55.0.15",
    "expo-localization": "~55.0.14",
    "expo-notifications": "~55.0.23",
    "expo-router": "~55.0.14",
    "expo-secure-store": "~55.0.14",
    "expo-speech-recognition": "^3.0.1",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-system-ui": "~55.0.18",
    "expo-updates": "~55.0.22",
    "expo-web-browser": "~55.0.16",
    "i18next": "^26.0.3",
    "nativewind": "4.2.4",
    "react": "19.2.0",
    "react-error-boundary": "^6.1.1",
    "react-i18next": "^17.0.2",
    "react-native": "0.83.6",
    "react-native-css-interop": "0.2.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-sms-android": "2.1.0",
    "react-native-gifted-charts": "^1.4.70",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-reanimated": "4.2.1",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-worklets": "0.7.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "cross-env": "^10.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^6.1.1",
    "eslint-plugin-react-native": "^4.1.0",
    "jest-expo": "~55.0.17",
    "react-dom": "19.2.0",
    "react-native-svg-transformer": "^1.5.2",
    "react-test-renderer": "19.2.0",
    "tailwindcss": "^3.4.18",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  }
}
